{
  "compilerOptions": {
    "target": "ES2020",

    "module": "CommonJS",

    "moduleResolution": "node",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": ["node"],

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],

  "exclude": ["node_modules"]
}